{
  "version": 1,
  "privateNetwork": "boske-net",
  "privateNetworkCIDR": "10.0.0.0/16",
  "appGroupIdentifier": "group.eu.canopystudio.boske.pulse",
  "discovery": {
    "enabled": true,
    "preferCoolify": true,
    "includeUnmatchedHetzner": true
  },
  "servers": [],
  "serverOverlays": [
    {
      "match": { "coolifyName": "canopy-websites" },
      "role": "Coolify — canopy portfolio sites"
    },
    {
      "match": { "coolifyName": "boske-website", "hetznerName": "boske-website" },
      "role": "Coolify — boske.dev website",
      "publicEndpoints": [
        { "id": "website", "label": "boske.dev", "url": "https://boske.dev/", "expectStatus": 200 }
      ]
    },
    {
      "match": { "coolifyName": "boske-app-01", "hetznerName": "boska-app-01" },
      "role": "Cloud API",
      "publicEndpoints": [
        { "id": "app", "label": "app.boske.dev", "url": "https://app.boske.dev/api/health", "expectStatus": 200 }
      ],
      "manualStack": [
        { "name": "boske-app-api", "role": "api", "linkedEndpointID": "app" },
        { "name": "boske-app-postgres", "role": "postgres" },
        { "name": "boske-app-redis", "role": "redis" },
        { "name": "boske-app-meili", "role": "meilisearch" },
        { "name": "boske-app-minio", "role": "minio" },
        { "name": "boske-app-vectordb", "role": "pgvector" },
        { "name": "boske-app-rag-api", "role": "rag" },
        { "name": "boske-app-stt", "role": "stt" }
      ]
    },
    {
      "match": { "hetznerName": "boske-data-01" },
      "role": "Licensing PG + data stack",
      "privateProbes": [
        { "id": "licensing-pg", "label": "licensing PG", "host": "10.0.0.2", "port": 5433 }
      ]
    },
    {
      "match": { "hetznerName": "boske-search-01" },
      "role": "SearXNG + Valkey + Caddy",
      "publicEndpoints": [
        { "id": "search", "label": "search.boske.dev", "url": "https://search.boske.dev/", "expectStatus": 200, "acceptStatuses": [200, 403] }
      ],
      "manualStack": [
        { "name": "searxng", "role": "searxng", "linkedEndpointID": "search" },
        { "name": "valkey", "role": "cache" },
        { "name": "caddy", "role": "proxy" }
      ]
    },
    {
      "match": { "hetznerName": "boske-llm-01" },
      "role": "LLM proxy + Caddy",
      "publicEndpoints": [
        {
          "id": "llm-healthz",
          "label": "llm.boske.dev",
          "url": "https://llm.boske.dev/healthz",
          "expectStatus": 200,
          "expectBodyContains": "\"ok\":true"
        }
      ],
      "manualStack": [
        { "name": "llm-proxy", "role": "proxy", "linkedEndpointID": "llm-healthz" },
        { "name": "caddy", "role": "proxy" }
      ]
    }
  ],
  "coolify": {
    "dashboardPath": "/",
    "apiPath": "/api/v1"
  },
  "alerts": {
    "debounceSeconds": 300,
    "flapIgnoreSeconds": 120,
    "telegramEnabled": true
  },
  "polling": {
    "publicHealthSeconds": 30,
    "coolifySeconds": 60,
    "hetznerSeconds": 120,
    "privateProbeSeconds": 60
  }
}
