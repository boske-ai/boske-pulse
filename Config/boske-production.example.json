{
  "version": 1,
  "privateNetwork": "example-net",
  "privateNetworkCIDR": "10.99.0.0/16",
  "appGroupIdentifier": "group.eu.canopystudio.boske.pulse",
  "discovery": {
    "enabled": true,
    "preferCoolify": true,
    "includeUnmatchedHetzner": true
  },
  "servers": [],
  "serverOverlays": [
    {
      "match": { "coolifyName": "portfolio-sites" },
      "role": "Coolify — static portfolio sites"
    },
    {
      "match": { "coolifyName": "example-website", "hetznerName": "example-website" },
      "role": "Marketing website",
      "publicEndpoints": [
        { "id": "website", "label": "example.dev", "url": "https://example.dev/", "expectStatus": 200 }
      ]
    },
    {
      "match": { "coolifyName": "example-app-01", "hetznerName": "examp-app-01" },
      "role": "Application API",
      "publicEndpoints": [
        { "id": "app", "label": "app.example.dev", "url": "https://app.example.dev/api/health", "expectStatus": 200 }
      ],
      "manualStack": [
        { "name": "example-app-api", "role": "api", "linkedEndpointID": "app" },
        { "name": "example-app-postgres", "role": "postgres" },
        { "name": "example-app-redis", "role": "redis" },
        { "name": "example-app-search", "role": "meilisearch" },
        { "name": "example-app-storage", "role": "object-storage" },
        { "name": "example-app-vectordb", "role": "pgvector" },
        { "name": "example-app-rag", "role": "rag" },
        { "name": "example-app-stt", "role": "stt" }
      ]
    },
    {
      "match": { "hetznerName": "example-data-01" },
      "role": "Data stack",
      "privateProbes": [
        { "id": "postgres", "label": "Postgres", "host": "10.99.0.2", "port": 5433 }
      ]
    },
    {
      "match": { "hetznerName": "example-search-01" },
      "role": "Search + cache + proxy",
      "publicEndpoints": [
        { "id": "search", "label": "search.example.dev", "url": "https://search.example.dev/", "expectStatus": 200, "acceptStatuses": [200, 403] }
      ],
      "manualStack": [
        { "name": "search", "role": "search", "linkedEndpointID": "search" },
        { "name": "cache", "role": "cache" },
        { "name": "proxy", "role": "proxy" }
      ]
    },
    {
      "match": { "hetznerName": "example-llm-01" },
      "role": "LLM proxy",
      "publicEndpoints": [
        {
          "id": "llm-healthz",
          "label": "llm.example.dev",
          "url": "https://llm.example.dev/healthz",
          "expectStatus": 200,
          "expectBodyContains": "\"ok\":true"
        }
      ],
      "manualStack": [
        { "name": "llm-proxy", "role": "proxy", "linkedEndpointID": "llm-healthz" },
        { "name": "proxy", "role": "proxy" }
      ]
    }
  ],
  "coolify": {
    "dashboardPath": "/",
    "apiPath": "/api/v1"
  },
  "alerts": {
    "debounceSeconds": 300,
    "flapIgnoreSeconds": 120,
    "telegramEnabled": true
  },
  "polling": {
    "publicHealthSeconds": 30,
    "coolifySeconds": 60,
    "hetznerSeconds": 120,
    "privateProbeSeconds": 60
  }
}
